# Copier ce fichier vers .env et adapter.

# URL de ton site (Render) — sans slash à la fin
API_URL=https://qualitedelair.onrender.com

# Même clé que la variable SENSOR_API_KEY sur Render (laisser vide si non utilisée)
SENSOR_API_KEY=

# Secondes entre deux envois
INTERVAL_SEC=5

# 1 = données simulées (pour tester sans capteurs branchés)
MOCK_MODE=1
