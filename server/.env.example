PORT=4000
# Origines autorisées (CORS + Socket.io), séparées par des virgules — ex. ton site Netlify
ALLOWED_ORIGINS=http://localhost:5173,https://ton-site.netlify.app
# Clé partagée avec le Raspberry Pi (header X-API-Key). Laisser vide en dev local sans protection.
SENSOR_API_KEY=
# Mettre à 1 sur le serveur de prod quand le Pi envoie les vraies données
DISABLE_MOCK=0
